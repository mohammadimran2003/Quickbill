generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALESMAN
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  phone    String?  @unique
  address  String?
  photo    String?
  password String
  role     Role   @default(SALESMAN)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  walletTransactions WalletTransaction[]
  products Product[]
  catagories  Category[]
  brands  Brand[]
  priceTiers  PriceTier[]
  productVariants   ProductVariant[]
  customers Customer[]
  purchases Purchase[]
  returns Return[]
  expenses Expense[]
  draftOrders DraftOrder[]
}

enum ProductType {
  SIMPLE
  VARIANT
  COMPOSITE
}

enum Unit {
  PCS
  KG
  GRAM
  LITRE
  DOZEN
  METER
  BOX
}

enum DiscountType {
  NONE
  FLAT
  PERCENTAGE
}

enum CustomerType {
  REGULAR
  WHOLESALE
  VIP
}

model Customer {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  phone         String       @unique
  email         String?      @unique
  address       String?
  customerType  CustomerType @default(REGULAR)
  creditLimit   Float        @default(0)
  totalSpent    Float        @default(0)
  totalDue      Float        @default(0)
  walletBalance Float        @default(0)
  note          String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])
  orders        Order[]
  walletTransactions WalletTransaction[]
  draftOrders DraftOrder[]
}


model DraftOrder {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  name       String?     
  customerId String?     @db.ObjectId
  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      Json        // cart items array save korbe
  createdBy  String      @db.ObjectId
  user       User        @relation(fields: [createdBy], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum WalletTransactionType {
  RECHARGE   // taka add hoyeche
  PAYMENT    // order a wallet theke kata hoyeche
  DUE_PAYMENT  // due payment hoyeche
}

model WalletTransaction {
  id           String                @id @default(auto()) @map("_id") @db.ObjectId
  customerId   String                @db.ObjectId
  customer     Customer              @relation(fields: [customerId], references: [id])

  type         WalletTransactionType
  amount       Float                 // total koto taka dilo
  dueDeduction Float @default(0)     // due theke koto katlo
  walletCredit Float @default(0)     // wallet a koto gelo
  note         String?

  createdBy    String                @db.ObjectId
  user         User                  @relation(fields: [createdBy], references: [id])
  createdAt    DateTime              @default(now())
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])

  products    Product[]
}

model Brand {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique
  description String?
  logo        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])

  products    Product[]
}

model Product {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Info
  name            String
  description     String?
  images          String[]
  barcode         String?     @unique
  barcodeImage    String?
  sku             String?     @unique
  productType     ProductType @default(SIMPLE)

  // Categorization
  categoryId      String      @db.ObjectId
  category        Category    @relation(fields: [categoryId], references: [id])
  brandId         String?     @db.ObjectId
  brand           Brand?      @relation(fields: [brandId], references: [id])

  // Base Pricing 
  costPrice       Float      
  basePrice       Float      

  // Discount
  discountType    DiscountType  @default(NONE)
  discountValue   Float?

  // Stock
  stock           Int         @default(0)
  lowStockAlert   Int         @default(5)
  unit            Unit        @default(PCS)

  // Extra
  taxRate         Float       @default(0)
  isActive        Boolean     @default(true)
  tags            String[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])
  priceTiers      PriceTier[] //ekti product er onk gulo priceTiers thakte pare
  variants        ProductVariant[]
  orderItems       OrderItem[]
  purchaseItems   PurchaseItem[]

}

enum TierName {
  RETAIL
  WHOLESALE
  VIP
  SPECIAL
}


model PriceTier {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  productId String    @db.ObjectId
  product   Product   @relation(fields: [productId], references: [id])

  name      TierName  // RETAIL, WHOLESALE, VIP, SPECIAL
  minQty    Int      //koto quantity theke ei price apply hobe
  price     Float     

  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([productId, name])
}

model Supplier {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String?    @unique
  email       String?    @unique
  address     String?
  note        String?
  isActive    Boolean    @default(true)

  totalSpent    Float     @default(0) 
  totalDue      Float     @default(0) 
  walletBalance Float     @default(0)  

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  purchases   Purchase[]
}

enum PurchaseStatus {
  ORDERED    
  RECEIVED   
  CANCELLED  
}

model PurchaseCounter {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  value Int    @default(0)
}

model Purchase {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  purchaseNumber String         @unique  // PUR-0001
  supplierId     String?        @db.ObjectId
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])

  items          PurchaseItem[]
  returns        Return[]

  subTotal       Float
  total          Float
  paidAmount     Float          @default(0)
  dueAmount      Float          @default(0)

  status         PurchaseStatus @default(RECEIVED)
  note           String?
  paymentMethod  PaymentMethod
  createdBy      String         @db.ObjectId
  user           User           @relation(fields: [createdBy], references: [id])

  // date
  date      DateTime @default(now())
  
  month     String   // "Jan", "Feb", "Mar"
  year      Int      // 2026

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PurchaseItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  purchaseId   String   @db.ObjectId
  purchase     Purchase @relation(fields: [purchaseId], references: [id])
  productId    String   @db.ObjectId
  product      Product  @relation(fields: [productId], references: [id])

  productName  String?   
  quantity     Int
  returnedQty  Int      @default(0)
  unitCost     Float    
  total        Float    

  createdAt    DateTime @default(now())
}

enum OrderStatus {
  COMPLETED
  PENDING
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
  UNPAID
}

enum OrderType {
  WALK_IN
  DELIVERY
}

//counter model for order number generate;
model Counter {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  value Int    @default(0)
}

model Order {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber    String        @unique

  // Customer
  customerName  String?
  customerId     String?       @db.ObjectId
  customer       Customer?     @relation(fields: [customerId], references: [id])

  //user
  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])

  // Order Items
  items          OrderItem[]

  // Pricing
  subtotal       Float         // discount, tax chara total
  discountType   DiscountType?
  discountValue  Float         @default(0)
  discountAmount Float         @default(0)
  taxAmount      Float         @default(0)
  total          Float        
  totalCostPrice Float         @default(0) // profit hiseber jonno

  // Payment
  paymentMethod  PaymentMethod @default(CASH)
  amountPaid     Float
  changeAmount   Float         @default(0)
  dueAmount      Float         @default(0)

  // date
  date      DateTime @default(now())
  
  month     String   // "Jan", "Feb", "Mar"
  year      Int      // 2026

  // return 
  returns        Return[]

  // Extra
  orderType      OrderType     @default(WALK_IN)
  note           String?
  status         OrderStatus   @default(COMPLETED)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OrderItem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String   @db.ObjectId
  order         Order    @relation(fields: [orderId], references: [id])
  productId     String   @db.ObjectId
  product       Product  @relation(fields: [productId], references: [id])

  productName   String   // sei somoyer product name
  unitPrice     Float    // bikroy mullo
  purchasePrice Float    // kroy mullo  (profit hisaber jonno)
  quantity      Int
  returnedQty   Int      @default(0)
  discount      Float    @default(0)
  total         Float    // (unitPrice - discount) * quantity

  createdAt     DateTime @default(now())
}

model returnCounter {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  currentNumber Int      @default(1)
  createdAt     DateTime @default(now())
}

enum ReturnType {
  PURCHASE
  SALE
}

// main return model puro return transaction track korbe
model Return {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  returnNo      String       @unique // example: RET-1001, RET-1002
  returnType    ReturnType   // "PURCHASE" or "SALE" (same model can handle both)
  
  // kharidor kache theke return asche or kharidor kache jachche
  customerId    String?      @db.ObjectId
  supplierId    String?      @db.ObjectId
  
  // original invoice or purchase order ke link kora
  orderId       String?      @db.ObjectId // sale return hole
  purchaseId    String?      @db.ObjectId // purchase return hole

  // tk er hisab
  totalAmount   Float        // return korar somoy total amount
  tax           Float        @default(0)
  grandTotal    Float        // taxsah koto tk ferot deowa holo

  // extra
  reason        String?

  // return item gulo ke relation kora
  items         ReturnItem[]
  order         Order?     @relation(fields: [orderId], references: [id])
  purchase      Purchase?  @relation(fields: [purchaseId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  createdBy String @db.ObjectId
  user      User   @relation(fields: [createdBy], references: [id])
}

model ReturnItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  returnId   String   @db.ObjectId
  return     Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId  String   @db.ObjectId
  
  quantity   Int      // koto piece return kora holo
  price      Float    // return korar somoy price
  total      Float    // quantity * price
}

model Store {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  phone         String?
  email         String?
  address       String?
  logo          String?
  receiptFooter String?

  binNumber     String? 
  invoicePrefix String   @default("INV-") 
  timeZone      String   @default("Asia/Dhaka")

  currency      String   @default("৳")
  taxRate       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductVariant {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id])

  size       String?  // "S", "M", "L", "XL", "XXL"
  color      String?  // "Red", "Blue", "Black"
  stock      Int      @default(0)
  extraPrice Float    @default(0) // base price er upore koto barbe

  createdBy   String   @db.ObjectId
  user     User     @relation(fields: [createdBy], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
} 

model ExpenseCategory {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique // jemon: Rent, Utilities, Salaries, Damaged Goods
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

enum ExpensePaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_BANKING
  OTHER
}

model Expense {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  title         String          // "May maser bhara", "Kormochari beton"
  amount        Float

  // date
  date      DateTime @default(now())
  month     String   // "Jan", "Feb", "Mar"
  year      Int      // 2026

  categoryId    String          @db.ObjectId
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethod ExpensePaymentMethod
  note          String?
  referenceId   String?
  createdBy     String          @db.ObjectId  
  user          User            @relation(fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt   
}